{
  "version": 1,
  "fields": {
    "v": "schema version",
    "seq": "telemetry sequence",
    "up": "uptime milliseconds",
    "spd": "vehicle speed km/h",
    "rpm": "engine rpm",
    "clt": "coolant temperature celsius",
    "wt": "weather temperature celsius",
    "wc": "weather code (WMO)",
    "bat": "battery millivolts",
    "fuel": "fuel level percent",
    "rng": "estimated range km",
    "acc": "longitudinal acceleration milli-g",
    "wifi": "wifi connected flag 0 or 1",
    "hl": "headlights flag 0 or 1",
    "obd": "obd link live flag 0 or 1",
    "fresh": "fresh telemetry flag 0 or 1",
    "el": "engine load percent (OBD PID 0x04)",
    "map": "manifold absolute pressure kPa (OBD PID 0x0B)",
    "baro": "barometric pressure kPa (OBD PID 0x33)",
    "boost": "turbo boost bar (computed: (map-baro)/100)",
    "lat_g": "lateral g-force",
    "lon_g": "longitudinal g-force",
    "fr": "fuel rate litres per hour (OBD PID 0x5E)"
  }
}